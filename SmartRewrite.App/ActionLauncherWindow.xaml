<Window x:Class="SmartRewrite.App.ActionLauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="260"
        Height="160"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True">
    <Border CornerRadius="22"
            Background="#FF10131A"
            BorderBrush="#FF2A3442"
            BorderThickness="1"
            Padding="18">
        <StackPanel>
            <TextBlock Text="SmartWrite"
                       Foreground="#FFB8FFCF"
                       FontSize="14"
                       FontWeight="SemiBold" />
            <TextBlock Text="Selected text is ready."
                       Foreground="White"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,8,0,0" />
            <Button Content="Open SmartWrite"
                    Margin="0,18,0,0"
                    Padding="0,10"
                    Background="#FF36A268"
                    BorderThickness="0"
                    Foreground="White"
                    Click="OpenButton_Click" />
        </StackPanel>
    </Border>
</Window>
