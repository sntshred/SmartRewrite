<Window x:Class="SmartRewrite.App.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="300"
        Height="150"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True">
    <Border CornerRadius="22"
            Background="#FF10131A"
            BorderBrush="#FF2A3442"
            BorderThickness="1"
            Padding="18">
        <StackPanel>
            <TextBlock Text="SmartWrite"
                       Foreground="#FFB8FFCF"
                       FontSize="14"
                       FontWeight="SemiBold" />
            <TextBlock Text="Creating 3 professional variations..."
                       Foreground="White"
                       FontSize="18"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0" />
        </StackPanel>
    </Border>
</Window>
